{
  "mcpServers": {
    "12306-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "12306-mcp"
      ]
    },
    "amap-maps-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ]
    },
    "wecom": {
      "command": "uvx",
      "args": [
        "wecom-bot-mcp-server"
      ]
    },
    "BOSS": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-boss-zp"
      ],
      "disabled": false
    },
    "playwright": {
      "name": "playwright",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "tavily-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ]
    },
    "firecrawl-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ]
    },
    "arxiv-paper-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@langgpt/arxiv-paper-mcp@latest"
      ]
    },

    "zread": {
      "type": "streamableHttp",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer ${ZREAD_API_KEY}"
      }
    },

    "yuque-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "yuque-mcp",
        "start",
        "--client=vscode"
      ]
    },
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${STITCH_API_KEY}"
      }
    },
    "mastergo": {
      "command": "npx",
      "args": [
        "-y",
        "@mastergo/vibe-mcp",
        "--url=http://localhost:50678"
      ]
    },
    "mastergo-magic-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@mastergo/magic-mcp",
        "--url=https://mastergo.com"
      ]
    },
    "Redis": {
      "command": "redis",
      "args": [
        "-e",
        "REDIS_URL=\"redis://localhost:6379\"",
        "--",
        "npx",
        "@modelcontextprotocol/server-redis"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}
