# === 运行态配置（template 输出，含真实密钥，禁止提交） ===
# config/ 目录：由 template/ 模板生成的运行态文件，含真实 API Key
/config/

# 根目录本地密钥/运行态文件（禁止提交）
/llm.yaml
/mcp.yaml
env.local.yaml
opencode.json
skills-lock.json
temp_parse.py

# Codex 运行态配置（由脚本生成）
.codex/

# === 临时/缓存 ===
.DS_Store
.agents
.idea
.claude
.qoder
.trae
.cursor/
.specstory/

# === Python ===
# 字节码文件 / 编译产物
__pycache__/
*.py[cod]
*$py.class
*.so

# 分发 / 打包
build/
dist/
*.egg-info/
*.egg

# 虚拟环境
.venv/
venv/
env/
ENV/

# 前端工程（Vue 3 + Vite）
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
tools/dist-ui/

# 工具缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyc/

# 环境变量文件
.env
.env.local
.env.*.local

# npx skills add 全局安装的远程技能缓存（项目根 skills/，非 template/skills）
/skills/

# PyInstaller 构建产物
/build/
/dist/
*.spec.bak
# frozen 首次运行标记
.bundle_bootstrapped
.zcode/
# .workbuddy 运行态目录（含 mcp.json / models.json 等，由应用运行时生成）
.workbuddy/
