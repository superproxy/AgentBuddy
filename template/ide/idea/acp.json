{
  "default_mcp_settings": {
    "use_idea_mcp": true,
    "use_custom_mcp": true
  },
  "agent_servers": {
    "我的codex": {
      "command": "npx",
      "args": [
        "@zed-industries/codex-acp"
      ]
    },
    "我的claude": {
      "command": "npx",
      "args": [
        "@zed-industries/claude-code-acp"
      ],
      "env": {
        "ACP_PERMISSION_MODE": "bypassPermissions"
      }
    },

    "我的opencode": {
      "type": "custom",
      "command": "opencode",
      "args": [
        "acp"
      ],
      "env": {}
    },

    "我的TRAE": {
      "type": "custom",
      "command": "traecli",
      "args": [
        "acp",
        "serve"
      ],
      "env": {}
    }
  }
}
